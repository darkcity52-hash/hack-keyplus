# --- LÓGICA DE VIBRACIÓN (Android) ---
try:
    from jnius import autoclass
    PythonActivity = autoclass('org.kivy.android.PythonActivity')
    Context = autoclass('android.content.Context')
    Vibrator = PythonActivity.mActivity.getSystemService(Context.VIBRATOR_SERVICE)
    HAS_VIBRATOR = True
except:
    HAS_VIBRATOR = False

def vibrate():
    if HAS_VIBRATOR:
        try: Vibrator.vibrate(25)
        except: pass

# --- WIDGET TECLA ---
class KeyButton(Button):
    def __init__(self, key_label, width_mult, **kwargs):
        super().__init__(**kwargs)
        self.key_label = key_label
        self.text = key_label
        self.width_mult = width_mult
        self.background_normal = ''
        self.background_down = ''
        self.font_size = dp(14)
        self.markup = True

    def apply_theme(self, theme_name):
        t = THEMES[theme_name]
        self.background_color = t['key_bg']
        self.color = t['key_color']

# --- APLICACIÓN PRINCIPAL ---
class HackKeyboardApp(App):
    current_theme = StringProperty("Matrix")
    key_size = NumericProperty(1.0)

    def build(self):
        self.title = "Hack Keyboard Pro"
        Window.clearcolor = THEMES[self.current_theme]['bg']
        
        self.root = BoxLayout(orientation='vertical', padding=dp(5), spacing=dp(2))
        
        # 1. Barra Superior
        self.build_top_bar()
        
        # 2. Área de Texto
        self.display = TextInput(
            size_hint_y=0.3,
            background_color=THEMES[self.current_theme]['txt_bg'],
            foreground_color=THEMES[self.current_theme]['txt_color'],
            cursor_color=THEMES[self.current_theme]['txt_color'],
            font_name='RobotoMono',
            font_size=dp(18),
            multiline=True
        )
        self.root.add_widget(self.display)

        # 3. Contenedor del Teclado
        self.keyboard_container = BoxLayout(orientation='vertical', spacing=dp(3))
        self.root.add_widget(self.keyboard_container)
        
        self.build_keyboard()
        
        # Bindings para actualización automática
        self.bind(current_theme=self.update_theme)
        self.bind(key_size=self.update_sizes)
        
        return self.root

    def build_top_bar(self):
        bar = BoxLayout(size_hint_y=0.06, spacing=dp(5))
        
        btn_settings = Button(text='⚙ AJUSTES', font_size=dp(12), background_color=(0.2,0.2,0.2,1))
        btn_settings.bind(on_press=self.open_settings)
        
        btn_copy = Button(text='📋 COPIAR', font_size=dp(12), background_color=(0.1,0.3,0.1,1))
        btn_copy.bind(on_press=self.copy_text)
        
        bar.add_widget(btn_settings)
        bar.add_widget(btn_copy)
        self.root.add_widget(bar)

    def build_keyboard(self):
        self.keyboard_container.clear_widgets()
        self.keys_list = []

        for row_data in KEYS_LAYOUT:
            row_layout = BoxLayout(spacing=dp(3))
            for key_label, width_mult in row_data:
                btn = KeyButton(key_label, width_mult)
                btn.apply_theme(self.current_theme)
                
                # Asignar tamaño
                btn.size_hint_x = width_mult
                
                # Eventos
                btn.bind(on_press=self.on_key_press)
                btn.bind(on_release=self.on_key_release)
                
                self.keys_list.append(btn)
                row_layout.add_widget(btn)
            self.keyboard_container.add_widget(row_layout)

    def on_key_press(self, instance):
        vibrate()
        t = THEMES[self.current_theme]
        instance.background_color = t['active']
        instance.color = (0,0,0,1) # Texto negro al
